DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=

# Chain selection: '0g' | 'xlayer' | 'bnb' (default: '0g')
NEXT_PUBLIC_CHAIN=0g
# Set to 'true' to use testnet (default: false)
NEXT_PUBLIC_USE_TESTNET=true

NEXT_PUBLIC_WC_PROJECT_ID=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_WEATHER_AUCTION_ADDRESS=
NEXT_PUBLIC_VEHICLE_RENT_ADDRESS=
NEXT_PUBLIC_MEME_MARKET_ADDRESS=
NEXT_PUBLIC_INDEXER_GRAPHQL_URL=
NEXT_PUBLIC_SKILL_PROVIDER=
NEXT_PUBLIC_ONCHAIN_OS_MCP_URL=

# Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# API auth (optional — protects /api/0g-storage POST in production)
API_SECRET=
NEXT_PUBLIC_API_SECRET=

# Supabase (real-time presence, leaderboard, weather sync)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Marble World (World Labs Marble / Spark integration)
# Server-side script key. Never expose this as NEXT_PUBLIC_*.
WLT_API_KEY=
MARBLE_WORLD_MODEL=marble-1.1
MARBLE_WORLD_DISPLAY_NAME=Clawdy Marble Arena
MARBLE_WORLD_PROMPT=
MARBLE_SPZ_RESOLUTION=500k

# Set NEXT_PUBLIC_MARBLE_ENABLED=true to activate the marble world layer
NEXT_PUBLIC_MARBLE_ENABLED=false
NEXT_PUBLIC_MARBLE_SPLAT_URL=
NEXT_PUBLIC_MARBLE_SPLAT_FORMAT=spz
NEXT_PUBLIC_MARBLE_COLLIDER_URL=
NEXT_PUBLIC_MARBLE_WORLD_ID=clawdy-marble-arena
NEXT_PUBLIC_MARBLE_WORLD_NAME=Clawdy Marble Arena
NEXT_PUBLIC_MARBLE_BOUNDS=50,20,50
NEXT_PUBLIC_MARBLE_SPAWN_BOUNDS=50,5,50
NEXT_PUBLIC_MARBLE_SPAWN_HEIGHT=18
